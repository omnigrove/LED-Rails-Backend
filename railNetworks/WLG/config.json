{
  "GTFSRealtimeAPI": {
    "url": ["https://api.opendata.metlink.org.nz/v1/gtfs-rt/vehiclepositions"],
    "keyHeader": "x-api-key",
    "fetchIntervalSeconds": 10,
    "format": "FeedMessage",
    "protocol": "protobuf"
  },
  "trainFilter": {
    "trip_ID": {
      "includes": ["RAIL"]
    }
  },
  "processingOptions": {
    "pairTrains": false,
    "cacheGTFS": true,
    "cacheTrackedTrains": true,
    "cacheIntervalSeconds": 360,
    "displayThreshold": 120
  },
  "trackBlocks": {
    "fileName": "trackBlocks.kml"
  },
  "LEDRailsAPI": {
    "APIVersions": [{ "version": "100" }],
    "randomizeTimeOffset": true,
    "colors": {
      "OUT-OF-SERVICE": [255, 0, 0],
      "2": [159, 223, 0],
      "3": [255, 96, 128],
      "4": [255, 191, 0],
      "5": [255, 96, 0],
      "6": [0, 191, 191]
    }
  }
}
